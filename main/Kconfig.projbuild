menu "alc-gw-p4 Relay Configuration"

    config RELAY_RTSP_URL
        string "C212 RTSP URL (stream2, 転送用、認証情報は含めない)"
        default "rtsp://192.168.1.50:554/stream2"
        help
            C212 の転送用 RTSP URL (360p サブストリーム)。ローカル表示は
            行わないため stream1 とは別。docs/whip-convention.md 参照。
            認証情報は埋め込まず RELAY_RTSP_USERNAME/PASSWORD を使う
            (esp_media_protocols 時代の user:pass@ 埋め込みは自前RTSP
            クライアント (rtsp_client) への置き換えで廃止、alc-gw-p4#1)。

    config RELAY_RTSP_USERNAME
        string "C212 RTSP username (RTSP Digest認証)"
        default ""
        help
            RTSP Digest 認証のユーザー名。空なら認証なしとして接続する。

    config RELAY_RTSP_PASSWORD
        string "C212 RTSP password (RTSP Digest認証)"
        default ""
        help
            RTSP Digest 認証のパスワード。

    config RELAY_SIGNALING_URL
        string "Camera signaling room WebSocket URL"
        default ""
        help
            wss://<signaling>/cam-room/<拠点ID> 形式 (role=device は
            signaling_client が自動付与)。ippoan/alc-app cf-alc-signaling
            の CameraSignalingRoom (ippoan/alc-app#129) と話す。旧
            WHIP publish endpoint (https://<sfu>/ingest/<拠点ID>) から
            置き換え。空なら relay_task 自体を起動しない (relay.c 参照) —
            以前はダミーの example.workers.dev を既定にしていたため、未設定の
            まま起動すると DNS 解決失敗の再接続ループが priority 5 で回り
            続け、priority 2 の console REPL タスクが実質的に応答不能になる
            事故があった。

    config RELAY_SIGNALING_TOKEN
        string "Signaling Bearer token (拠点トークン、フォールバック用静的値)"
        default ""
        help
            device credential ('cred set <id> <secret>' で注入) が設定済み
            なら auth-worker (POST /device/cam-relay-token) から都度 mint
            した token を優先して使う (alc-gw-p4#2)。credential 未設定、
            または mint に失敗した場合のみ、この静的値 (キッティング時の
            埋め込み、旧 v1 方式) にフォールバックする。DO 側はまだこの
            ヘッダを検証しない (camera-relay-convention.md 参照)。

    config RELAY_AUTH_WORKER_URL
        string "auth-worker base URL (hub_link 相互認証・カメラ中継token mint用)"
        default "https://auth.ippoan.org"
        help
            POST /device/hub-token・POST /device/introspect
            (ippoan/auth-worker#406、ippoan/alc-app-s3#83 GW側実装) と
            POST /device/cam-relay-token (alc-gw-p4#2)・POST /device/token
            (alc-gw-p4#15、recorder_link用) 共通の宛先。staging で検証する
            場合は auth-staging.ippoan.org 等に変更する。

    config RECORDER_LINK_URL
        string "Recorder uplink WebSocket URL (cf-alc-recorder /ws)"
        default ""
        help
            wss://<recorder>/ws 形式。device JWT (RELAY_AUTH_WORKER_URL 経由で
            POST /device/token を mint) を Authorization: Bearer で付けて常時
            接続し、admin dashboard (auth-worker /device/setup) の「接続」
            「バージョン」列を role=device-gateway でも機能させる
            (alc-gw-p4#15)。空なら recorder_link 自体を起動しない
            (RELAY_SIGNALING_URL と同じ規約)。

endmenu
